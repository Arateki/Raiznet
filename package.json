{
  "name": "raiznet",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dashboard:build": "pnpm --filter @raiznet/dashboard build",
    "dashboard:dev": "pnpm --filter @raiznet/dashboard dev",
    "dashboard:preview": "pnpm --filter @raiznet/dashboard preview",
    "prototype:build": "pnpm --filter @raiznet/prototype build",
    "prototype:dev": "pnpm --filter @raiznet/prototype dev",
    "prototype:preview": "pnpm --filter @raiznet/prototype preview",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "website:build": "pnpm --filter @raiznet/website build",
    "website:dev": "pnpm --filter @raiznet/website dev",
    "website:preview": "pnpm --filter @raiznet/website preview"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.6.0",
    "@bufbuild/buf": "^1.54.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
